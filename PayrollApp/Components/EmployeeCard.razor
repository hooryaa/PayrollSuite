@* EmployeeCard - DevExpress Card Component
   Renders a modern KPI card using DxCard for dashboard statistics.
   Component lifecycle: initial render shows placeholder; parent supplies data after loading.
   Data binding: Title, Value, and Detail parameters bound from parent.
   Event handling: purely presentational.
   Dependency Injection: receives data via parameters.
*@

<div class="dx-metric-card dx-card">
    <div class="dx-card-stat-container">
        <div class="dx-card-stat-title">@Title</div>
        <div class="dx-card-stat-value">@Value</div>
        <div class="dx-card-stat-detail">@Detail</div>
    </div>
</div>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public string Detail { get; set; } = string.Empty;
}
