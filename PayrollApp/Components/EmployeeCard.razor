@* EmployeeCard - dashboard metric card
   Renders a KPI summary card with title, value, and detail text.
*@

<div class="dx-metric-card dx-card">
    <div class="dx-card-stat-container">
        <div class="dx-card-stat-title">@Title</div>
        <div class="dx-card-stat-value">@Value</div>
        <div class="dx-card-stat-detail">@Detail</div>
    </div>
</div>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public string Detail { get; set; } = string.Empty;
}
