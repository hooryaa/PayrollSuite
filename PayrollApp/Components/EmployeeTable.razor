@using DevExpress.Blazor

@* EmployeeTable - DevExpress Grid Component
   Renders employee list using DxGrid with sorting, filtering, paging, and actions.
*@

@if (Employees?.Any() != true)
{
    <div class="dx-empty-state-card">
        <div class="dx-empty-state">
            <div class="dx-empty-icon">📭</div>
            <p class="dx-empty-message">No employees match the filter.</p>
        </div>
    </div>
}
else
{
    <DxGrid Data="@Employees"
            PageSize="10"
            AllowPaging="true"
            AllowSorting="true"
            AllowFiltering="true"
            FilterRowVisible="true"
            ShowGroupPanel="true"
            AllowColumnResizing="true"
            PageIndex="0"
            AllowSelectRowByClick="true"
            CssClass="dx-employee-grid"
            SelectionMode="GridSelectionMode.Single">
        
        <DxGridDataColumn FieldName="EmployeeNumber" Caption="Employee #" Width="12%" />
        <DxGridDataColumn FieldName="FirstName" Caption="First Name" Width="15%" />
        <DxGridDataColumn FieldName="LastName" Caption="Last Name" Width="15%" />
        <DxGridDataColumn FieldName="DepartmentName" Caption="Department" Width="18%" SortOrder="GridColumnSortOrder.Ascending">
            <DisplayTemplate>
                @RenderDepartment(GetDepartmentId((EmployeeViewModel)context))
            </DisplayTemplate>
        </DxGridDataColumn>
        <DxGridDataColumn FieldName="HireDate" Caption="Hire Date" Width="14%">
            <DisplayTemplate>
                @((EmployeeViewModel)context).HireDate.ToString("MMM dd, yyyy")
            </DisplayTemplate>
        </DxGridDataColumn>
        <DxGridDataColumn FieldName="IsActive" Caption="Status" Width="12%">
            <DisplayTemplate>
                @{
                    var emp = (EmployeeViewModel)context;
                    var statusClass = emp.IsActive ? "dx-badge-success" : "dx-badge-inactive";
                    var statusText = emp.IsActive ? "Active" : "Inactive";
                }
                <span class="dx-badge @statusClass">@statusText</span>
            </DisplayTemplate>
        </DxGridDataColumn>
        
        <DxGridCommandColumn Width="14%">
            <CellDisplayTemplate Context="context">
                @{
                    var emp = (EmployeeViewModel)context;
                }
                <DxButton RenderStyle="ButtonRenderStyle.Link" 
                          Text="View" 
                          IconCssClass="oi oi-eye"
                          Click="@(async () => await OnViewEmployee.InvokeAsync(emp.EmployeeID))" />
                
                <DxButton RenderStyle="ButtonRenderStyle.Link" 
                          Text="Edit" 
                          IconCssClass="oi oi-pencil"
                          Click="@(async () => await OnEditEmployee.InvokeAsync(emp.EmployeeID))" />
                
                <DxButton RenderStyle="ButtonRenderStyle.Link" 
                          Text="Delete" 
                          IconCssClass="oi oi-trash"
                          Click="@(async () => await ConfirmDelete(emp.EmployeeID))" />
            </CellDisplayTemplate>
        </DxGridCommandColumn>
    </DxGrid>
}

<DxPopup @ref="deletePopup" HeaderText="Confirm Delete" CssClass="dx-confirm-dialog">
    <BodyTemplate>
        <p class="dx-dialog-message">Are you sure you want to delete this employee?</p>
        <div class="dx-dialog-actions">
            <DxButton Text="Cancel" RenderStyle="ButtonRenderStyle.Secondary" Click="@(async () => await deletePopup.CloseAsync())" />
            <DxButton Text="Delete" RenderStyle="ButtonRenderStyle.Danger" Click="@ConfirmDeleteAction" />
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    [Parameter]
    public IEnumerable<EmployeeViewModel>? Employees { get; set; }

    [Parameter]
    public EventCallback<int> OnViewEmployee { get; set; }

    [Parameter]
    public EventCallback<int> OnEditEmployee { get; set; }

    [Parameter]
    public EventCallback<int> OnDeleteEmployee { get; set; }

    private DxPopup deletePopup = null!;
    private int pendingDeleteId;

    private async Task ConfirmDelete(int employeeId)
    {
        pendingDeleteId = employeeId;
        await deletePopup.ShowAsync();
    }

    private async Task ConfirmDeleteAction()
    {
        await deletePopup.CloseAsync();
        await OnDeleteEmployee.InvokeAsync(pendingDeleteId);
    }

    private static string RenderDepartment(int? id)
    {
        return id switch
        {
            1 => "Human Resources",
            2 => "Finance",
            3 => "Operations",
            4 => "IT",
            5 => "Sales",
            _ => "Unassigned"
        };
    }

    private static int? GetDepartmentId(EmployeeViewModel emp)
    {
        return emp.DepartmentID;
    }
}
