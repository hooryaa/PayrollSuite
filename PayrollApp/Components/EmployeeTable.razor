@using DevExpress.Blazor

@if (Employees?.Any() != true)
{
    <div class="dx-empty-state-card">
        <div class="dx-empty-state">
            <div class="dx-empty-icon">📭</div>
            <div>
                <h3>No results yet</h3>
                <p>Try expanding your search or add a new employee to populate this list.</p>
            </div>
        </div>
    </div>
}
else
{
    <div class="dx-dashboard-employee-list">
        @foreach (var employee in Employees)
        {
            <article class="dx-employee-card dx-card-elevated">
                <div class="dx-employee-card-header">
                    <div class="dx-employee-avatar">@GetInitials(employee)</div>
                    <div>
                        <div class="dx-employee-name">@employee.FirstName @employee.LastName</div>
                        <div class="dx-employee-meta">@employee.EmployeeNumber · @RenderDepartment(employee.DepartmentID)</div>
                    </div>
                </div>
                <div class="dx-employee-card-footer">
                    <span class="dx-status-pill @(employee.IsActive ? "dx-status-active" : "dx-status-inactive")">
                        @(employee.IsActive ? "Active" : "Inactive")
                    </span>
                    <div class="dx-row-actions">
                        <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                                  IconCssClass="oi oi-eye"
                                  Click="@(async () => await OnViewEmployee.InvokeAsync(employee.EmployeeID))"
                                  CssClass="dx-icon-action" />
                        <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                                  IconCssClass="oi oi-pencil"
                                  Click="@(async () => await OnEditEmployee.InvokeAsync(employee.EmployeeID))"
                                  CssClass="dx-icon-action" />
                        <DxButton RenderStyle="ButtonRenderStyle.Danger"
                                  IconCssClass="oi oi-trash"
                                  Click="@(async () => await ConfirmDelete(employee.EmployeeID))"
                                  CssClass="dx-icon-action" />
                    </div>
                </div>
            </article>
        }
    </div>
}

<DxPopup @ref="deletePopup" HeaderText="Confirm Delete" CssClass="dx-modal-popup dx-confirm-dialog" Width="420" Height="auto" CloseOnOutsideClick="false" ShowTitle="true" AllowResize="false" AllowDrag="false">
    <BodyTemplate>
        <div class="dx-dialog-content">
            <p class="dx-dialog-message">Are you sure you want to delete this employee?</p>
            <div class="dx-dialog-actions">
                <DxButton Text="Cancel" RenderStyle="ButtonRenderStyle.Secondary" Click="@(async () => await deletePopup.CloseAsync())" CssClass="dx-button-secondary" />
                <DxButton Text="Delete" RenderStyle="ButtonRenderStyle.Danger" Click="@ConfirmDeleteAction" CssClass="dx-button-danger" />
            </div>
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    [Parameter]
    public IEnumerable<EmployeeViewModel>? Employees { get; set; }

    [Parameter]
    public EventCallback<int> OnViewEmployee { get; set; }

    [Parameter]
    public EventCallback<int> OnEditEmployee { get; set; }

    [Parameter]
    public EventCallback<int> OnDeleteEmployee { get; set; }

    private DxPopup deletePopup = null!;
    private int pendingDeleteId;

    private async Task ConfirmDelete(int employeeId)
    {
        pendingDeleteId = employeeId;
        await deletePopup.ShowAsync();
    }

    private async Task ConfirmDeleteAction()
    {
        await deletePopup.CloseAsync();
        await OnDeleteEmployee.InvokeAsync(pendingDeleteId);
    }

    private static string RenderDepartment(int? id)
    {
        return id switch
        {
            1 => "Human Resources",
            2 => "Finance",
            3 => "Operations",
            4 => "IT",
            5 => "Sales",
            _ => "Unassigned"
        };
    }

    private static string GetInitials(EmployeeViewModel employee)
    {
        return string.Concat(employee.FirstName?.FirstOrDefault(), employee.LastName?.FirstOrDefault()).ToUpperInvariant();
    }
}
