@* EmployeeSearchFilter - DevExpress Components
   Modern search and filter panel with DxTextBox and DxComboBox
*@
<div class="dx-filter-card">
    <div class="dx-filter-container">
        <div class="dx-filter-row">
            <div class="dx-filter-col">
                <DxTextBox @bind-Value="@SearchTerm" 
                           CssClass="dx-search-input"
                           Placeholder="🔍 Search by name or employee number"
                           IconPosition="EditorIconPosition.Right"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
            </div>

            <div class="dx-filter-col">
                <DxComboBox Data="@departmentOptions"
                            @bind-Value="@DepartmentId"
                            ValueFieldName="Key"
                            TextFieldName="Value"
                            CssClass="dx-department-select"
                            Placeholder="Select department"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                            AllowUserInput="false" />
            </div>

            <div class="dx-filter-actions">
                <DxButton Text="Clear Filters" 
                          RenderStyle="ButtonRenderStyle.Secondary"
                          Click="@ResetFilters"
                          IconCssClass="oi oi-x" />
            </div>
        </div>
    </div>
</div>

@code {
    private string searchTerm = string.Empty;
    private int? departmentId;

    private string SearchTerm
    {
        get => searchTerm;
        set
        {
            if (searchTerm != value)
            {
                searchTerm = value;
                _ = OnFilterChangedAsync();
            }
        }
    }

    private int? DepartmentId
    {
        get => departmentId;
        set
        {
            if (departmentId != value)
            {
                departmentId = value;
                _ = OnFilterChangedAsync();
            }
        }
    }

    private readonly List<KeyValuePair<int, string>> departmentOptions = new()
    {
        new KeyValuePair<int, string>(0, "All Departments"),
        new KeyValuePair<int, string>(1, "Human Resources"),
        new KeyValuePair<int, string>(2, "Finance"),
        new KeyValuePair<int, string>(3, "Operations"),
        new KeyValuePair<int, string>(4, "IT"),
        new KeyValuePair<int, string>(5, "Sales")
    };

    [Parameter]
    public EventCallback<EmployeeFilterModel> OnFilterChanged { get; set; }

    private async Task OnFilterChangedAsync()
    {
        await OnFilterChanged.InvokeAsync(new EmployeeFilterModel
        {
            SearchTerm = searchTerm,
            DepartmentId = departmentId == 0 ? null : departmentId
        });
    }

    private async Task ResetFilters()
    {
        SearchTerm = string.Empty;
        DepartmentId = null;
        await OnFilterChangedAsync();
    }
}
