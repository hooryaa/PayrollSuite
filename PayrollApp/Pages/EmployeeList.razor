@page "/employees"
@inject IEmployeeApiService EmployeeService
@inject NavigationManager NavigationManager

@using PayrollApp.Models
@using DevExpress.Blazor

<div class="dx-page-heading">
    <div>
        <p class="dx-badge-label">Employees</p>
        <h1>Team Directory</h1>
        <p class="dx-page-intro">Manage employee records, departmental assignments, and status across the organization.</p>
    </div>
    <DxButton Text="New Employee"
              IconCssClass="oi oi-plus"
              RenderStyle="ButtonRenderStyle.Primary"
              Click="@OpenCreatePopup"
              CssClass="dx-button-primary" />
</div>

@if (!string.IsNullOrEmpty(notificationMessage))
{
    <div class="dx-toast dx-toast-@notificationLevel">
        <span>@notificationMessage</span>
        <button class="dx-toast-close" @onclick="ClearNotification">×</button>
    </div>
}

<div class="dx-table-toolbar">
    <div class="dx-search-input-wrapper">
        <span class="oi oi-magnifying-glass dx-search-icon"></span>
        <input type="search"
               @bind="toolbarSearchTerm"
               placeholder="Search employees, departments, IDs..."
               class="dx-search-input" />
    </div>
    <DxComboBox Data="@departmentOptions"
                @bind-Value="toolbarDepartmentId"
                ValueFieldName="Key"
                TextFieldName="Value"
                CssClass="dx-filter-select"
                AllowUserInput="false"
                Placeholder="All Departments" />
    <div class="dx-toolbar-actions">
        <DxButton Text="Apply"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  IconCssClass="oi oi-magnifying-glass"
                  Click="@ApplyFilters"
                  CssClass="dx-button-secondary" />
        <DxButton Text="Refresh"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  IconCssClass="oi oi-reload"
                  Click="@LoadEmployeesAsync"
                  CssClass="dx-button-secondary" />
    </div>
</div>

<div class="dx-table-card dx-card-elevated">
    @if (isLoading)
    {
        <div class="dx-loading-card">
            <DxLoadingPanel Visible="true" ShowPane="false" />
            <div class="dx-loading-label">Loading team data…</div>
        </div>
    }
    else if (!filteredEmployees.Any())
    {
        <div class="dx-empty-state-card">
            <div class="dx-empty-state">
                <div class="dx-empty-icon">📭</div>
                <div>
                    <h3>No employees found</h3>
                    <p>Try adjusting the search or department filter.</p>
                    <DxButton Text="Add Employee"
                              RenderStyle="ButtonRenderStyle.Primary"
                              IconCssClass="oi oi-plus"
                              Click="@OpenCreatePopup"
                              CssClass="dx-button-primary" />
                </div>
            </div>
        </div>
    }
    else
    {
        <DxDataGrid Data="@filteredEmployees"
                    ColumnAutoWidth="false"
                    ShowFilterRow="false"
                    ShowColumnChooser="true"
                    ShowGroupPanel="false"
                    PagerVisible="true"
                    PageSize="12"
                    CssClass="dx-employee-grid">
            <Columns>
                <DxDataGridColumn Caption="Employee" Width="320px">
                    <CellDisplayTemplate Context="employee">
                        <div class="dx-employee-cell">
                            <div class="dx-employee-avatar">@GetInitials(employee)</div>
                            <div>
                                <div class="dx-employee-name">@employee.FirstName @employee.LastName</div>
                                <div class="dx-employee-meta">@employee.EmployeeNumber</div>
                            </div>
                        </div>
                    </CellDisplayTemplate>
                </DxDataGridColumn>
                <DxDataGridColumn Field="@nameof(EmployeeViewModel.Email)" Caption="Email" Width="260px" />
                <DxDataGridColumn Field="@nameof(EmployeeViewModel.DepartmentID)" Caption="Department" Width="180px">
                    <CellDisplayTemplate Context="employee">
                        <span class="dx-status-pill dx-pill-secondary">@GetDepartmentName(employee.DepartmentID)</span>
                    </CellDisplayTemplate>
                </DxDataGridColumn>
                <DxDataGridColumn Field="@nameof(EmployeeViewModel.HireDate)" Caption="Hire Date" Width="150px" DisplayFormat="{0:MMM dd, yyyy}" />
                <DxDataGridColumn Caption="Status" Width="140px">
                    <CellDisplayTemplate Context="employee">
                        <span class="dx-status-pill @(employee.IsActive ? "dx-status-active" : "dx-status-inactive")">
                            @(employee.IsActive ? "Active" : "Inactive")
                        </span>
                    </CellDisplayTemplate>
                </DxDataGridColumn>
                <DxDataGridColumn Caption="Actions" Width="180px">
                    <CellDisplayTemplate Context="employee">
                        <div class="dx-row-actions">
                            <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                                      IconCssClass="oi oi-eye"
                                      Click="@(async () => ViewEmployee(employee.EmployeeID))"
                                      CssClass="dx-icon-action" />
                            <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                                      IconCssClass="oi oi-pencil"
                                      Click="@(async () => OpenEditPopup(employee.EmployeeID))"
                                      CssClass="dx-icon-action" />
                            <DxButton RenderStyle="ButtonRenderStyle.Danger"
                                      IconCssClass="oi oi-trash"
                                      Click="@(async () => ConfirmDeleteEmployee(employee.EmployeeID))"
                                      CssClass="dx-icon-action" />
                        </div>
                    </CellDisplayTemplate>
                </DxDataGridColumn>
            </Columns>
        </DxDataGrid>
    }
</div>

<DxPopup @ref="employeePopup"
         CssClass="dx-modal-popup"
         HeaderText="@(isEditMode ? \"Edit Employee\" : \"Create Employee\")"
         Width="760"
         Height="auto"
         Visible="@isPopupVisible"
         CloseOnOutsideClick="false"
         ShowTitle="true"
         AllowResize="false"
         AllowDrag="false"
         VisibleChanged="@(visible => isPopupVisible = visible)">
    <BodyTemplate>
        <EmployeeFormDialog Model="popupModel"
                            IsEdit="isEditMode"
                            IsBusy="isPopupSaving"
                            OnValidSubmit="HandlePopupSubmit"
                            OnCancel="ClosePopup" />
    </BodyTemplate>
</DxPopup>

<DxPopup @ref="deletePopup"
         CssClass="dx-modal-popup"
         HeaderText="Confirm Delete"
         Width="420"
         Height="auto"
         Visible="@isDeletePopupVisible"
         CloseOnOutsideClick="false"
         ShowTitle="true"
         AllowResize="false"
         AllowDrag="false"
         VisibleChanged="@((visible) => isDeletePopupVisible = visible)">
    <BodyTemplate>
        <div class="dx-dialog-content">
            <p>Are you sure you want to delete this employee?</p>
            <div class="dx-dialog-actions">
                <DxButton Text="Cancel"
                          RenderStyle="ButtonRenderStyle.Secondary"
                          Click="@CloseDeletePopup"
                          CssClass="dx-button-secondary" />
                <DxButton Text="Delete"
                          RenderStyle="ButtonRenderStyle.Danger"
                          Click="@DeleteEmployeeConfirmed"
                          CssClass="dx-button-danger" />
            </div>
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    private List<EmployeeViewModel> allEmployees = new();
    private List<EmployeeViewModel> filteredEmployees = new();
    private bool isLoading = true;
    private bool isPopupVisible;
    private bool isPopupSaving;
    private bool isDeletePopupVisible;
    private bool isEditMode;
    private int selectedDeleteId;
    private string notificationMessage = string.Empty;
    private string notificationLevel = "success";
    private string toolbarSearchTerm = string.Empty;
    private int toolbarDepartmentId;
    private EmployeeEditModel popupModel = new();
    private DxPopup employeePopup = null!;
    private DxPopup deletePopup = null!;

    private readonly List<KeyValuePair<int, string>> departmentOptions = new()
    {
        new KeyValuePair<int, string>(0, "All Departments"),
        new KeyValuePair<int, string>(1, "Human Resources"),
        new KeyValuePair<int, string>(2, "Finance"),
        new KeyValuePair<int, string>(3, "Operations"),
        new KeyValuePair<int, string>(4, "IT"),
        new KeyValuePair<int, string>(5, "Sales")
    };

    protected override async Task OnInitializedAsync()
    {
        toolbarDepartmentId = 0;
        await LoadEmployeesAsync();
    }

    private async Task LoadEmployeesAsync()
    {
        isLoading = true;
        StateHasChanged();

        allEmployees = await EmployeeService.GetAllAsync();
        ApplyFilter();
        isLoading = false;
    }

    private void ApplyFilter()
    {
        filteredEmployees = allEmployees
            .Where(e => string.IsNullOrWhiteSpace(toolbarSearchTerm)
                || e.FirstName.Contains(toolbarSearchTerm, StringComparison.OrdinalIgnoreCase)
                || e.LastName.Contains(toolbarSearchTerm, StringComparison.OrdinalIgnoreCase)
                || e.EmployeeNumber.Contains(toolbarSearchTerm, StringComparison.OrdinalIgnoreCase)
                || (e.Email ?? string.Empty).Contains(toolbarSearchTerm, StringComparison.OrdinalIgnoreCase))
            .Where(e => toolbarDepartmentId == 0 || e.DepartmentID == toolbarDepartmentId)
            .OrderBy(e => e.LastName)
            .ThenBy(e => e.FirstName)
            .ToList();
    }

    private void ApplyFilters()
    {
        ApplyFilter();
    }

    private void ClearNotification()
    {
        notificationMessage = string.Empty;
    }

    private void OpenCreatePopup()
    {
        popupModel = new EmployeeEditModel();
        isEditMode = false;
        isPopupVisible = true;
    }

    private void OpenEditPopup(int employeeId)
    {
        var employee = allEmployees.FirstOrDefault(e => e.EmployeeID == employeeId);
        if (employee == null)
        {
            ShowNotification("Employee not found.", "error");
            return;
        }

        popupModel = new EmployeeEditModel
        {
            EmployeeID = employee.EmployeeID,
            EmployeeNumber = employee.EmployeeNumber,
            FirstName = employee.FirstName,
            LastName = employee.LastName,
            Email = employee.Email,
            Phone = employee.Phone,
            HireDate = employee.HireDate,
            IsActive = employee.IsActive,
            DepartmentID = employee.DepartmentID,
            PositionID = employee.PositionID,
            EmploymentType = employee.EmploymentType,
            WorkEmail = employee.WorkEmail
        };

        isEditMode = true;
        isPopupVisible = true;
    }

    private async Task HandlePopupSubmit(EmployeeEditModel model)
    {
        isPopupSaving = true;

        try
        {
            if (isEditMode && model.EmployeeID.HasValue)
            {
                await EmployeeService.UpdateAsync(model.EmployeeID.Value, model);
                ShowNotification("Employee updated successfully.", "success");
            }
            else
            {
                var created = await EmployeeService.CreateAsync(model);
                ShowNotification($"Employee {created.EmployeeNumber} created successfully.", "success");
            }

            await LoadEmployeesAsync();
            ClosePopup();
            popupModel = new EmployeeEditModel();
            isEditMode = false;
        }
        catch (HttpRequestException httpEx)
        {
            ShowNotification($"Unable to save employee: {httpEx.Message}", "error");
        }
        catch (Exception)
        {
            ShowNotification("Unable to save employee. Please try again.", "error");
        }
        finally
        {
            isPopupSaving = false;
        }
    }

    private void ClosePopup()
    {
        isPopupVisible = false;
    }

    private void ConfirmDeleteEmployee(int employeeId)
    {
        selectedDeleteId = employeeId;
        isDeletePopupVisible = true;
    }

    private async Task DeleteEmployeeConfirmed()
    {
        isDeletePopupVisible = false;

        try
        {
            await EmployeeService.DeleteAsync(selectedDeleteId);
            ShowNotification("Employee deleted successfully.", "success");
            await LoadEmployeesAsync();
        }
        catch
        {
            ShowNotification("Unable to delete employee. Please try again.", "error");
        }
    }

    private void CloseDeletePopup()
    {
        isDeletePopupVisible = false;
    }

    private void ViewEmployee(int id)
    {
        NavigationManager.NavigateTo($"/employees/{id}");
    }

    private void ShowNotification(string text, string level)
    {
        notificationMessage = text;
        notificationLevel = level;
    }

    private static string GetInitials(EmployeeViewModel employee)
    {
        return string.Concat(employee.FirstName?.FirstOrDefault(), employee.LastName?.FirstOrDefault()).ToUpperInvariant();
    }

    private static string GetDepartmentName(int? departmentId)
    {
        return departmentId switch
        {
            1 => "Human Resources",
            2 => "Finance",
            3 => "Operations",
            4 => "IT",
            5 => "Sales",
            _ => "Unassigned"
        };
    }
}
