@page "/"
@inject IEmployeeApiService EmployeeService
@inject NavigationManager NavigationManager

@* Dashboard - DevExpress Components
   Modern dashboard with KPI cards, charts, and recent activity
*@

<div class="dx-page-header">
    <h2>Dashboard</h2>
    <p>Quick access to employee metrics, departmental coverage, and recent activity</p>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="dx-alert-card dx-alert-danger">
        <div class="dx-alert-content">
            <span class="dx-alert-icon">⚠️</span>
            <p>@errorMessage</p>
        </div>
    </div>
}

@if (isLoading)
{
    <div class="dx-loading-card">
        <div class="dx-loading-indicator">
            <p>Loading dashboard metrics...</p>
        </div>
    </div>
}
else
{
    <div class="dx-dashboard-grid">
        <div class="dx-kpi-cards">
            <EmployeeCard Title="Total Employees" Value="@totalEmployees.ToString()" Detail="All employees in system" />
            <EmployeeCard Title="Active Staff" Value="@activeEmployees.ToString()" Detail="Currently working employees" />
            <EmployeeCard Title="Departments" Value="@departmentCount.ToString()" Detail="Total departments" />
            <EmployeeCard Title="Recent Hires" Value="@recentHires.ToString()" Detail="Hired in last 90 days" />
        </div>

        <div class="dx-department-card">
            <div class="dx-card-header-with-action">
                <span class="dx-card-title">Department Staffing</span>
                <DxButton Text="Refresh" 
                         RenderStyle="ButtonRenderStyle.Link"
                         Click="@RefreshData"
                         IconCssClass="oi oi-reload" />
            </div>
            <div class="dx-card-body">
                @if (departmentChartData.Any())
                {
                    <div class="dx-department-grid">
                        @foreach (var dept in departmentChartData.OrderByDescending(d => d.EmployeeCount))
                        {
                            <div class="dx-department-item">
                                <div class="dx-dept-header">
                                    <span class="dx-dept-name">@dept.DepartmentName</span>
                                    <span class="dx-dept-count">@dept.EmployeeCount</span>
                                </div>
                                <div class="dx-dept-bar">
                                    <div class="dx-dept-bar-fill" 
                                         style="width: @(((decimal)dept.EmployeeCount / departmentChartData.Max(d => d.EmployeeCount)) * 100)%">
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="dx-empty-message">No department data available</p>
                }
            </div>
        </div>

        <div class="dx-recent-hires-card">
            <div class="dx-card-header-with-action">
                <span class="dx-card-title">Recent Hires</span>
                <DxButton Text="View All" 
                         RenderStyle="ButtonRenderStyle.Link"
                         Click="@(() => NavigationManager.NavigateTo("/employees"))"
                         IconCssClass="oi oi-arrow-right" />
            </div>
            <div class="dx-card-body">
                @if (recentHireList.Any())
                {
                    <EmployeeTable Employees="@recentHireList" 
                                  OnViewEmployee="ViewEmployee" 
                                  OnEditEmployee="EditEmployee" 
                                  OnDeleteEmployee="DeleteEmployee" />
                }
                else
                {
                    <div class="dx-empty-section">
                        <p class="dx-empty-icon">👤</p>
                        <p class="dx-empty-message">No recent hires in the last 90 days</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="dx-dashboard-footer">
        <p>Last updated: @DateTime.Now.ToString("MMM dd, yyyy HH:mm:ss")</p>
    </div>
}

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private int totalEmployees;
    private int activeEmployees;
    private int departmentCount;
    private int recentHires;
    private List<EmployeeViewModel> recentHireList = new();
    private List<DepartmentChartItem> departmentChartData = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var allEmployees = await EmployeeService.GetAllAsync();
            totalEmployees = allEmployees.Count;
            activeEmployees = allEmployees.Count(e => e.IsActive);
            departmentCount = allEmployees.Select(e => e.DepartmentID).Where(id => id.HasValue).Distinct().Count();

            var cutoff = DateTime.Today.AddDays(-90);
            recentHireList = allEmployees
                .Where(e => e.HireDate >= cutoff)
                .OrderByDescending(e => e.HireDate)
                .Take(5)
                .ToList();

            recentHires = recentHireList.Count;
            departmentChartData = allEmployees
                .Where(e => e.DepartmentID.HasValue)
                .GroupBy(e => e.DepartmentID)
                .Select(g => new DepartmentChartItem
                {
                    DepartmentName = RenderDepartment(g.Key),
                    EmployeeCount = g.Count()
                })
                .OrderByDescending(item => item.EmployeeCount)
                .ToList();
        }
        catch (Exception)
        {
            errorMessage = "Payroll API is unavailable. Start the backend on https://localhost:5001 and reload the page.";
            totalEmployees = 0;
            activeEmployees = 0;
            departmentCount = 0;
            recentHires = 0;
            recentHireList = new();
            departmentChartData = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefreshData()
    {
        await LoadDashboardAsync();
    }

    private void ViewEmployee(int id)
    {
        NavigationManager.NavigateTo($"/employees/{id}");
    }

    private void EditEmployee(int id)
    {
        NavigationManager.NavigateTo($"/employees/edit/{id}");
    }

    private async Task DeleteEmployee(int id)
    {
        await EmployeeService.DeleteAsync(id);
        await LoadDashboardAsync();
    }

    private static string RenderDepartment(int? id)
    {
        return id switch
        {
            1 => "Human Resources",
            2 => "Finance",
            3 => "Operations",
            4 => "IT",
            5 => "Sales",
            _ => "Unassigned"
        };
    }

    private class DepartmentChartItem
    {
        public string DepartmentName { get; set; } = string.Empty;
        public int EmployeeCount { get; set; }
    }
}

