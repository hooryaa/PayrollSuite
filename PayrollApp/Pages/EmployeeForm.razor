@page "/employees/create"
@page "/employees/edit/{EmployeeId:int}"
@inject IEmployeeApiService EmployeeService
@inject NavigationManager NavigationManager

@* Employee Form - DevExpress Components
   Modern create/edit form using DxFormLayout, DxTextBox, DxDateEdit, etc.
*@

<div class="dx-page-header">
    <h2>@(isEdit ? "✏️ Edit Employee" : "➕ Create Employee")</h2>
    <p>@(isEdit ? "Update employee information" : "Add a new employee to the payroll system")</p>
</div>

@if (isLoading)
{
    <div class="dx-loading-card">
        <div class="dx-loading-spinner">
            <p>Loading form...</p>
        </div>
    </div>
}
else
{
    <div class="dx-form-card">
        <div class="dx-card-body">
            <EditForm Model="formModel" OnValidSubmit="HandleValidSubmit">
                <DataAnnotationsValidator />

                <DxFormLayout CssClass="dx-employee-form">
                    <DxFormLayoutGroup Caption="Personal Information" ColSpanMd="12">
                        <DxFormLayoutItem ColSpanMd="6">
                            <Template Context="ignored">
                                <label class="dx-form-label">Employee Number</label>
                                <DxTextBox @bind-Text="@formModel.EmployeeNumber"
                                           Enabled="@(!isEdit)"
                                           CssClass="dx-textbox-full" />
                                <ValidationMessage For="@(() => formModel.EmployeeNumber)" />
                            </Template>
                        </DxFormLayoutItem>

                        <DxFormLayoutItem ColSpanMd="6">
                            <Template Context="ignored">
                                <label class="dx-form-label">Employment Type</label>
                                <DxComboBox Data="@employmentTypes"
                                           @bind-Value="@formModel.EmploymentType"
                                           CssClass="dx-combobox-full"
                                           AllowUserInput="false" />
                                <ValidationMessage For="@(() => formModel.EmploymentType)" />
                            </Template>
                        </DxFormLayoutItem>

                        <DxFormLayoutItem ColSpanMd="6">
                            <Template Context="ignored">
                                <label class="dx-form-label">First Name *</label>
                                <DxTextBox @bind-Text="@formModel.FirstName" CssClass="dx-textbox-full" />
                                <ValidationMessage For="@(() => formModel.FirstName)" />
                            </Template>
                        </DxFormLayoutItem>

                        <DxFormLayoutItem ColSpanMd="6">
                            <Template Context="ignored">
                                <label class="dx-form-label">Last Name *</label>
                                <DxTextBox @bind-Text="@formModel.LastName" CssClass="dx-textbox-full" />
                                <ValidationMessage For="@(() => formModel.LastName)" />
                            </Template>
                        </DxFormLayoutItem>

                        <DxFormLayoutItem ColSpanMd="6">
                            <Template Context="ignored">
                                <label class="dx-form-label">Email *</label>
                                <DxTextBox @bind-Text="@formModel.Email"
                                          InputType="InputType.Email"
                                          CssClass="dx-textbox-full" />
                                <ValidationMessage For="@(() => formModel.Email)" />
                            </Template>
                        </DxFormLayoutItem>

                        <DxFormLayoutItem ColSpanMd="6">
                            <Template Context="ignored">
                                <label class="dx-form-label">Work Email</label>
                                <DxTextBox @bind-Text="@formModel.WorkEmail"
                                          InputType="InputType.Email"
                                          CssClass="dx-textbox-full" />
                                <ValidationMessage For="@(() => formModel.WorkEmail)" />
                            </Template>
                        </DxFormLayoutItem>

                        <DxFormLayoutItem ColSpanMd="6">
                            <Template Context="ignored">
                                <label class="dx-form-label">Phone *</label>
                                <DxTextBox @bind-Text="@formModel.Phone"
                                          InputType="InputType.Tel"
                                          CssClass="dx-textbox-full" />
                                <ValidationMessage For="@(() => formModel.Phone)" />
                            </Template>
                        </DxFormLayoutItem>

                        <DxFormLayoutItem ColSpanMd="6">
                            <Template Context="ignored">
                                <label class="dx-form-label">Department</label>
                                <DxComboBox Data="@departmentOptions"
                                           @bind-Value="@formModel.DepartmentID"
                                           ValueFieldName="Key"
                                           TextFieldName="Value"
                                           CssClass="dx-combobox-full"
                                           AllowUserInput="false" />
                            </Template>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>

                    <DxFormLayoutGroup Caption="Employment Details" ColSpanMd="12">
                        <DxFormLayoutItem ColSpanMd="6">
                            <Template Context="ignored">
                                <label class="dx-form-label">Hire Date *</label>
                                <DxDateEdit @bind-Date="@formModel.HireDate"
                                           T="DateTime"
                                           Enabled="@(!isEdit)"
                                           CssClass="dx-dateedit-full" />
                                <ValidationMessage For="@(() => formModel.HireDate)" />
                            </Template>
                        </DxFormLayoutItem>

                        <DxFormLayoutItem ColSpanMd="6">
                            <Template Context="ignored">
                                <label class="dx-form-label">Position ID</label>
                                <DxSpinEdit @bind-Value="@formModel.PositionID" CssClass="dx-spinedit-full" />
                            </Template>
                        </DxFormLayoutItem>

                        <DxFormLayoutItem ColSpanMd="12">
                            <Template Context="ignored">
                                <div class="dx-checkbox-wrapper">
                                    <DxCheckBox @bind-Checked="@formModel.IsActive" />
                                    <label class="dx-checkbox-label">Active Employee</label>
                                </div>
                            </Template>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>

                    <DxFormLayoutGroup Caption="Form Actions" ColSpanMd="12">
                        <DxFormLayoutItem ColSpanMd="12">
                            <Template Context="ignored">
                                <div class="dx-form-actions">
                                    <DxButton Text="Save"
                                             RenderStyle="ButtonRenderStyle.Primary"
                                             ButtonType="ButtonType.Submit"
                                             IconCssClass="oi oi-check"
                                             CssClass="dx-action-button" />
                                    <DxButton Text="Cancel"
                                             RenderStyle="ButtonRenderStyle.Secondary"
                                             Click="@Cancel"
                                             IconCssClass="oi oi-x"
                                             CssClass="dx-action-button" />
                                </div>
                            </Template>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>
                </DxFormLayout>

                <div class="dx-validation-summary">
                    <ValidationSummary />
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public int? EmployeeId { get; set; }

    private bool isEdit => EmployeeId.HasValue;
    private bool isLoading = true;
    private EmployeeEditModel formModel = new();

    private readonly List<KeyValuePair<int, string>> departmentOptions = new()
    {
        new KeyValuePair<int, string>(1, "Human Resources"),
        new KeyValuePair<int, string>(2, "Finance"),
        new KeyValuePair<int, string>(3, "Operations"),
        new KeyValuePair<int, string>(4, "IT"),
        new KeyValuePair<int, string>(5, "Sales")
    };

    private readonly List<string> employmentTypes = new()
    {
        "FullTime",
        "PartTime",
        "Contract",
        "Intern"
    };

    protected override async Task OnInitializedAsync()
    {
        if (isEdit)
        {
            var employee = await EmployeeService.GetByIdAsync(EmployeeId!.Value);
            if (employee != null)
            {
                formModel = new EmployeeEditModel
                {
                    EmployeeID = employee.EmployeeID,
                    EmployeeNumber = employee.EmployeeNumber,
                    FirstName = employee.FirstName,
                    LastName = employee.LastName,
                    Email = employee.Email,
                    Phone = employee.Phone,
                    HireDate = employee.HireDate,
                    IsActive = employee.IsActive,
                    DepartmentID = employee.DepartmentID,
                    PositionID = employee.PositionID,
                    EmploymentType = employee.EmploymentType,
                    WorkEmail = employee.WorkEmail
                };
            }
        }

        isLoading = false;
    }

    private async Task HandleValidSubmit()
    {
        if (isEdit)
        {
            await EmployeeService.UpdateAsync(EmployeeId!.Value, formModel);
            NavigationManager.NavigateTo($"/employees/{EmployeeId}");
        }
        else
        {
            var created = await EmployeeService.CreateAsync(formModel);
            NavigationManager.NavigateTo($"/employees/{created.EmployeeID}");
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo(isEdit ? $"/employees/{EmployeeId}" : "/employees");
    }
}
